RewriteEngine On

# Canonical host: redirect apex domain to www.
RewriteCond %{HTTP_HOST} ^asa-prenois-bourgogne\.org$ [NC]
RewriteRule ^ https://www.asa-prenois-bourgogne.org%{REQUEST_URI} [R=301,L]

# Canonical scheme: force HTTPS on production host.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^www\.asa-prenois-bourgogne\.org$ [NC]
RewriteRule ^ https://www.asa-prenois-bourgogne.org%{REQUEST_URI} [R=301,L]

# SPA fallback for clean URLs declared in sitemap.xml.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
